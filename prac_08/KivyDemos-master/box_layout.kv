BoxLayout:
    orientation: 'vertical'

    Button:
        text: 'Clear'
        on_press: app.handle_clear()

    TextInput:
        id: input_name
        hint_text: "Enter your name"

    Button:
        text: 'Greet'
        on_press: app.handle_pressed()

    Label:
        id: output_label
        text: ""
        color: (1, 1, 0, 1)







